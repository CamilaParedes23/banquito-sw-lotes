# banquito-switch-batch-service environment example
SERVER_PORT=8081

DB_URL=jdbc:postgresql://postgres:5432/SWITCH_LOTES_DB
DB_USERNAME=postgres
DB_PASSWORD=postgres

RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

RABBIT_EXCHANGE_BATCH=switch.batch.exchange
RABBIT_QUEUE_ROUTING_PAYMENT_LINES=switch.routing.payment-lines.queue
RABBIT_ROUTING_KEY_PAYMENT_LINE_REQUESTED=payment.line.requested

# Deprecated legacy Core gRPC settings
CORE_GRPC_HOST=core-banking-mock
CORE_GRPC_PORT=9090
CORE_GRPC_DEADLINE_MS=60000

# Core REST via Kong/API Manager
CORE_KONG_BASE_URL=http://35.238.255.174:8000
CORE_KONG_SWITCH_CORE_PATH=/api/v1/switch-core
CORE_KONG_PAYMENT_RESERVATIONS_PATH=/payment-reservations
CORE_KONG_AUTH_TOKEN=
CORE_KONG_CLIENT_TOKEN_ENABLED=true
CORE_KONG_CLIENT_ID=switch-pagos-internos-service
CORE_KONG_CLIENT_SECRET=password
CORE_KONG_REQUIRED_SCOPE=core.reserve.consume
CORE_KONG_CLIENT_TOKEN_PATH=/api/v1/auth/client-token
CORE_KONG_CLIENT_TOKEN_REFRESH_SKEW_SECONDS=60
CORE_KONG_CONNECT_TIMEOUT_MS=5000
CORE_KONG_READ_TIMEOUT_MS=30000
CORE_SWITCH_COMPANY_CUSTOMER_UUID=
CORE_SWITCH_DEFAULT_ACCOUNTING_DATE=
CORE_SWITCH_CHANNEL=SWITCH_API

GRPC_SERVER_PORT=9091
SWITCH_FILES_OUTPUT_DIRECTORY=/app/output
